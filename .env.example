SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_KEY=
NUXT_SUPABASE_SECRET_KEY=

# Public site URL (used in transactional emails, redirects)
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# Shared secret guarding POST /api/campaigns/process-due. Required to enable
# scheduled draining of pending campaign sends. Set to a long random string and
# call the endpoint with `Authorization: Bearer <secret>` from your scheduler
# of choice (Vercel Cron, systemd timer, pg_cron, GitHub Actions, ...).
CAMPAIGN_PROCESSOR_SECRET=

# Brevo (transactional email)
BREVO_API_KEY=
BREVO_WEBHOOK_SECRET=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=
BREVO_REPLY_TO=

# Payzen / Lyra REST API (used to generate payment links for "relance solde")
# https://docs.lyra.com/en/rest/V4.0/api/
PAYZEN_API_URL=https://api.lyra.com/api-payment/V4
PAYZEN_USERNAME=
PAYZEN_PASSWORD=
PAYZEN_HMAC_KEY=
PAYZEN_RETURN_URL=
# Forces Lyra to POST payment notifications to our webhook on every order,
# bypassing back-office IPN rules (the public website uses a different shop
# config). Defaults to `${NUXT_PUBLIC_SITE_URL}/api/webhooks/payzen` when unset.
PAYZEN_IPN_TARGET_URL=
# Email address that receives the payment receipt for every order created by
# this app (accounting BCC). Defaults to direct5@cia-france.com
PAYZEN_PAYMENT_RECEIPT_EMAIL=direct5@cia-france.com

# Brand identity injected into every email template (header, footer, signature,
# bank block). All fields fall back to CIA defaults if unset; override per env.
NUXT_PUBLIC_BRAND_LOGO_URL=https://www.cia-france.com/media/3339/logo-cia-horizontal_1151x320.png
NUXT_PUBLIC_BRAND_COMPANY_NAME=Centre International d'Antibes
NUXT_PUBLIC_BRAND_LEGAL_NAME=SAS CENTRE INTERNATIONAL ANTIBES
NUXT_PUBLIC_BRAND_ADDRESS_LINE1=38 Boulevard d'Aguillon
NUXT_PUBLIC_BRAND_ADDRESS_LINE2=
NUXT_PUBLIC_BRAND_POSTAL_CODE=06600
NUXT_PUBLIC_BRAND_CITY=Antibes
NUXT_PUBLIC_BRAND_COUNTRY=France
NUXT_PUBLIC_BRAND_PHONE=+33 4 92 90 71 72
NUXT_PUBLIC_BRAND_WEBSITE_URL=https://www.cia-france.com
NUXT_PUBLIC_BRAND_WEBSITE_LABEL=www.cia-france.com
NUXT_PUBLIC_BRAND_SUPPORT_EMAIL=direct@cia-france.com
NUXT_PUBLIC_BRAND_REPLY_TO_EMAIL=direct@cia-france.com
NUXT_PUBLIC_BRAND_TERMS_URL=https://www.cia-france.com/terms-and-conditions
NUXT_PUBLIC_BRAND_TAGLINE_FR=Don't learn French, live it!
NUXT_PUBLIC_BRAND_TAGLINE_EN=Don't learn French, live it!
NUXT_PUBLIC_BRAND_IBAN=FR63 3000 2032 3100 0007 4097 Y88
NUXT_PUBLIC_BRAND_BIC=CRLYFRPP
NUXT_PUBLIC_BRAND_BANK_NAME=
NUXT_PUBLIC_BRAND_SIGNATURE_NAME=Back Office Team
